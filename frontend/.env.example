# Copy this file to .env.local and adjust as needed.
# .env.local is gitignored — never commit real values.

# Set to true to run the full UI without a backend (uses in-memory mock data)
VITE_USE_MOCK=true

# TonightPick API base URL (only used when VITE_USE_MOCK=false)
VITE_API_URL=http://localhost:3001
